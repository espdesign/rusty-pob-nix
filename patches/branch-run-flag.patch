+/// Writes a dummy UpdateCheck.lua that does nothing to disable updates
+/// and updates its checksum in manifest.xml.
+fn disable_updatecheck<P: AsRef<Path>>(target_dir: P) -> anyhow::Result<()> {
+    let target_dir = target_dir.as_ref();
+    let file_path = target_dir.join("UpdateCheck.lua");
+    let content = "-- Updates disabled for custom branch/commit\n";
+    fs::write(&file_path, content)?;
+
+    let new_checksum = "31478ad4a2177bab36c93a9dc0e33dc409f79c64";
+    let manifest_path = target_dir.join("manifest.xml");
+    let manifest = fs::read_to_string(&manifest_path)?;
+    let new_manifest = replace_in_matching_lines(
+        &manifest,
+        r#"name="UpdateCheck.lua""#,
+        r#"sha1="([0-9A-Za-z]+)""#,
+        &format!(r#"sha1="{new_checksum}""#),
+    );
+    fs::write(&manifest_path, &new_manifest)?;
+
+    Ok(())
+}
