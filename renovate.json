{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDepNames": ["nixpkgs", "crane", "flake-utils"],
      "schedule": ["before 9am on Monday"]
    },
    {
      "matchDepNames": ["rusty-path-of-building"],
      "schedule": ["every hour"]
    }
  ]
}
